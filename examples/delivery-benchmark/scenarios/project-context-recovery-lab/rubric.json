{
  "id": "project-context-recovery-lab",
  "sections": {
    "acceptance": [
      {
        "id": "AC-CTX-001",
        "label": "API supports create/update/list/inspect incidents",
        "evidence": [
          { "path": "src/**", "contains_all": ["incident", "create", "update", "list"] },
          { "path": "tests/**", "contains_any": ["inspect", "GET", "POST", "update"] }
        ]
      },
      {
        "id": "AC-CTX-002",
        "label": "Board groups statuses and highlights risk",
        "evidence": [
          { "path": "src/**", "contains_all": ["new", "investigating", "mitigated", "resolved"] },
          { "path": "src/**", "contains_any": ["enterprise", "critical", "risk"] }
        ]
      },
      {
        "id": "AC-CTX-003",
        "label": "Owner/status movement persists with audit trail",
        "evidence": [
          { "path": "src/**", "contains_all": ["owner", "status", "auditTrail"] },
          { "path": "tests/**", "contains_any": ["owner", "status", "auditTrail"] }
        ]
      },
      {
        "id": "AC-CTX-004",
        "label": "Worker uses deterministic mock provider",
        "evidence": [
          { "path": "src/**", "contains_any": ["mock provider", "deterministicProviderEvents", "createMockProviderEvents"] },
          { "path": "src/**", "contains_all": ["providerEventId"] },
          { "path": "tests/**", "contains_any": ["mock provider", "fixture", "worker"] }
        ]
      },
      {
        "id": "AC-CTX-005",
        "label": "Provider idempotency exists",
        "evidence": [
          { "path": "src/**", "contains_any": ["idempotent", "duplicate", "providerEventId"] },
          { "path": "tests/**", "contains_any": ["idempotent", "duplicate", "providerEventId"] }
        ]
      },
      {
        "id": "AC-CTX-006",
        "label": "Bounded retry and dead-letter handling exist",
        "evidence": [
          { "path": "src/**", "contains_all": ["maxAttempts", "deadLetters"] },
          { "path": "tests/**", "contains_any": ["retry", "dead-letter"] }
        ]
      },
      {
        "id": "AC-CTX-007",
        "label": "Structured errors cover invalid input/state",
        "evidence": [
          { "path": "src/**", "contains_any": ["errorCode", "INVALID", "structured"] },
          { "path": "tests/**", "contains_any": ["INVALID", "state transition", "permission"] }
        ]
      },
      {
        "id": "AC-CTX-008",
        "label": "API, worker, and UI smoke tests exist",
        "evidence": [
          { "path": "tests/**", "contains_all": ["API", "worker"] },
          { "path": "tests/**", "contains_any": ["UI", "browser", "smoke", "playwright", "board"] }
        ]
      }
    ],
    "context_recovery": [
      {
        "id": "CTX-001",
        "label": "Fresh-agent recovery identifies runnable entrypoints",
        "evidence_mode": "any",
        "evidence": [
          { "path": "README.md", "contains_all": ["Entrypoints", "test"] },
          { "path": "docs/**", "contains_all": ["entrypoint", "test"] },
          { "path": "project_context/**", "contains_all": ["entrypoint", "test"] }
        ]
      },
      {
        "id": "CTX-002",
        "label": "Canonical data model and deprecated alias are documented",
        "evidence_mode": "any",
        "evidence": [
          { "path": "README.md", "contains_all": ["impactLevel", "severity", "deprecated"] },
          { "path": "docs/**", "contains_all": ["impactLevel", "severity", "deprecated"] },
          { "path": "project_context/**", "contains_all": ["impactLevel", "severity", "deprecated"] }
        ]
      },
      {
        "id": "CTX-003",
        "label": "Mock/live provider boundary is explicit",
        "evidence_mode": "any",
        "evidence": [
          { "path": "README.md", "contains_all": ["mock provider", "live provider"] },
          { "path": "docs/**", "contains_all": ["mock provider", "live provider"] },
          { "path": "project_context/**", "contains_all": ["mock provider", "live provider"] }
        ]
      },
      {
        "id": "CTX-004",
        "label": "Latest RFC/debug status is recoverable",
        "evidence_mode": "any",
        "evidence": [
          { "path": "README.md", "contains_any": ["RFC 1", "RFC 2", "Debug Fix", "next safe action"] },
          { "path": "docs/**", "contains_any": ["RFC 1", "RFC 2", "Debug Fix", "next safe action"] },
          { "path": "project_context/**", "contains_any": ["RFC 1", "RFC 2", "Debug Fix", "next safe action"] }
        ]
      }
    ],
    "rfc_debug": [
      {
        "id": "RFC-CTX-001",
        "label": "impactLevel is canonical while severity remains deprecated alias",
        "evidence": [
          { "path": "src/**", "contains_all": ["impactLevel", "severity"] },
          { "path": "tests/**", "contains_any": ["deprecated", "alias", "severity"] }
        ]
      },
      {
        "id": "RFC-CTX-002",
        "label": "New provider event names are used and old names rejected",
        "evidence": [
          { "path": "src/**", "contains_all": ["provider.incident.opened", "provider.incident.closed"] },
          { "path": "tests/**", "contains_any": ["incident.opened", "rejected", "INVALID_PROVIDER_EVENT"] }
        ]
      },
      {
        "id": "RFC-CTX-003",
        "label": "incident:write permission protects owner/status changes",
        "evidence": [
          { "path": "src/**", "contains_all": ["incident:write", "permission"] },
          { "path": "tests/**", "contains_any": ["incident:write", "permission"] }
        ]
      },
      {
        "id": "DEBUG-CTX-001",
        "label": "Debug evidence proves old provider event names are not accepted",
        "evidence": [
          { "path": "tests/**", "contains_all": ["incident.opened", "provider.incident.opened"] },
          { "path": "tests/**", "contains_any": ["Debug Fix", "rejects", "deprecated_provider_event_name", "INVALID_PROVIDER_EVENT"] }
        ]
      }
    ],
    "handoff": [
      {
        "id": "HANDOFF-CTX-001",
        "label": "Fresh-agent next safe action and test commands are documented",
        "evidence_mode": "any",
        "evidence": [
          { "path": "README.md", "contains_all": ["next safe action", "npm test"] },
          { "path": "docs/**", "contains_all": ["next safe action", "npm test"] },
          { "path": "project_context/**", "contains_all": ["next safe action", "npm test"] }
        ]
      }
    ]
  }
}
