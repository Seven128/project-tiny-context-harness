{
  "id": "expense-policy-engine",
  "sections": {
    "acceptance": [
      {
        "id": "AC-EXP-001",
        "label": "CLI accepts JSON file input and emits JSON output",
        "evidence": [
          { "path": "src/**", "contains_all": ["process.argv", "JSON.parse", "JSON.stringify"] },
          { "path": "tests/**", "contains_any": ["CLI", "spawn", "execFile"] }
        ]
      },
      {
        "id": "AC-EXP-002",
        "label": "Approved path has APPROVED reasonCode and auditTrail",
        "evidence": [
          { "path": "src/**", "contains_all": ["APPROVED", "auditTrail"] },
          { "path": "tests/**", "contains_all": ["APPROVED", "auditTrail"] }
        ]
      },
      {
        "id": "AC-EXP-003",
        "label": "Meal limit rejection is covered",
        "evidence": [
          { "path": "**", "contains_all": ["MEAL_LIMIT_EXCEEDED"] }
        ]
      },
      {
        "id": "AC-EXP-004",
        "label": "Missing receipt rejection is covered",
        "evidence": [
          { "path": "**", "contains_all": ["MISSING_RECEIPT"] }
        ]
      },
      {
        "id": "AC-EXP-005",
        "label": "Weekend travel review is covered",
        "evidence": [
          { "path": "**", "contains_all": ["WEEKEND_TRAVEL_REVIEW"] }
        ]
      },
      {
        "id": "AC-EXP-006",
        "label": "Executive limits and audit trail are represented",
        "evidence": [
          { "path": "src/**", "contains_all": ["executive", "auditTrail"] },
          { "path": "tests/**", "contains_all": ["executive"] }
        ]
      },
      {
        "id": "AC-EXP-007",
        "label": "Invalid input returns structured error",
        "evidence": [
          { "path": "**", "contains_all": ["INVALID_INPUT"] }
        ]
      },
      {
        "id": "AC-EXP-008",
        "label": "Tests cover key policy paths",
        "evidence": [
          { "path": "tests/**", "contains_all": ["MEAL_LIMIT_EXCEEDED", "MISSING_RECEIPT", "WEEKEND_TRAVEL_REVIEW", "INVALID_INPUT"] }
        ]
      },
      {
        "id": "AC-EXP-009",
        "label": "CLI smoke evidence exists",
        "evidence_mode": "any",
        "evidence": [
          { "path": "project_context/modules/*.md", "contains_any": ["CLI smoke", "npm test", "node"] },
          { "path": ".benchmark/**", "contains_any": ["CLI smoke", "npm test", "node"] }
        ]
      },
      {
        "id": "AC-EXP-010",
        "label": "Recovery facts exist",
        "evidence_mode": "any",
        "evidence": [
          { "path": "project_context/**", "contains_any": ["next action", "Current Blocker", "Testing Handoff Readiness", "resume"] },
          { "path": ".benchmark/**", "contains_any": ["next action", "recovery", "resume"] }
        ]
      }
    ],
    "change_impact": [
      {
        "id": "RFC-EXP-001",
        "label": "Parser accepts jurisdiction and deprecated region",
        "evidence": [
          { "path": "src/**", "contains_all": ["jurisdiction", "region"] },
          { "path": "tests/**", "contains_all": ["jurisdiction", "region"] }
        ]
      },
      {
        "id": "RFC-EXP-002",
        "label": "Audit output uses jurisdiction terminology",
        "evidence": [
          { "path": "**", "contains_all": ["jurisdiction"], "contains_any": ["deprecated", "alias"] }
        ]
      }
    ],
    "handoff": [
      {
        "id": "HANDOFF-EXP-001",
        "label": "Test report or transcript records executed gates",
        "evidence_mode": "any",
        "evidence": [
          { "path": "project_context/modules/*.md", "contains_any": ["PASS", "Test Matrix", "Regression Evidence"] },
          { "path": ".benchmark/**", "contains_any": ["PASS", "npm test", "smoke"] }
        ]
      }
    ]
  }
}
