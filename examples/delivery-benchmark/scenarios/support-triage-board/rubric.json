          { "path": "src/**", "contains_all": ["ticket", "create", "update", "list"] },
          { "path": "src/**", "contains_any": ["assign", "assignee", "move", "status"] }
        ]
      },
      {
        "id": "AC-SUP-002",
        "label": "Kanban and list views exist",
        "evidence": [
          { "path": "src/**", "contains_all": ["kanban", "list"] },
          { "path": "tests/**", "contains_any": ["kanban", "list", "browser", "UI"] }
        ]
      },
      {
        "id": "AC-SUP-003",
        "label": "Views show SLA, priority, owner, status, tier, channel, and contract risk",
        "evidence": [
          { "path": "src/**", "contains_all": ["SLA", "priorityScore", "owner", "status", "customerTier", "channel", "contractRisk"] }
        ]
      },
      {
