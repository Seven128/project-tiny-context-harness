{
  "id": "webhook-provider-bridge",
  "sections": {
    "acceptance": [
      {
        "id": "AC-WEB-001",
        "label": "HMAC verification exists",
        "evidence": [
          { "path": "src/**", "contains_all": ["HMAC", "signature"] },
          { "path": "tests/**", "contains_any": ["signature", "invalid"] }
        ]
      },
      {
        "id": "AC-WEB-002",
        "label": "Stale timestamps and replayed ids are rejected",
        "evidence": [
          { "path": "src/**", "contains_all": ["timestamp", "replay"] },
          { "path": "tests/**", "contains_any": ["stale", "replay"] }
        ]
      },
      {
        "id": "AC-WEB-003",
        "label": "Provider events are normalized",
        "evidence": [
          { "path": "src/**", "contains_any": ["normalize", "normalized"] },
          { "path": "tests/**", "contains_any": ["normalize", "eventType"] }
        ]
      },
      {
        "id": "AC-WEB-004",
        "label": "Idempotency by event id exists",
        "evidence": [
          { "path": "src/**", "contains_any": ["idempotent", "duplicate", "eventId"] },
          { "path": "tests/**", "contains_any": ["idempotent", "duplicate", "eventId"] }
        ]
      },
      {
        "id": "AC-WEB-005",
        "label": "Bounded retry/backoff exists",
        "evidence": [
          { "path": "src/**", "contains_all": ["retry", "backoff"] },
          { "path": "tests/**", "contains_any": ["retry", "backoff"] }
        ]
      },
      {
        "id": "AC-WEB-006",
        "label": "Dead-letter queue exists",
        "evidence": [
          { "path": "src/**", "contains_any": ["dead-letter", "deadLetter", "DLQ"] },
          { "path": "tests/**", "contains_any": ["dead-letter", "deadLetter", "DLQ"] }
        ]
      },
      {
        "id": "AC-WEB-007",
        "label": "Health/status entrypoint exists",
        "evidence": [
          { "path": "src/**", "contains_any": ["health", "status"] },
          { "path": "README.md", "contains_any": ["health", "status"] }
        ]
      },
      {
        "id": "AC-WEB-008",
        "label": "Mock provider fixture smoke is runnable",
        "evidence": [
          { "path": "tests/**", "contains_all": ["mock provider", "smoke"] },
          { "path": "README.md", "contains_any": ["mock provider", "fixture"] }
        ]
      }
    ],
    "context_recovery": [
      {
        "id": "CTX-WEB-001",
        "label": "Fresh-agent recovery identifies provider entrypoints",
        "evidence_mode": "any",
        "evidence": [
          { "path": "README.md", "contains_all": ["receiver", "health", "test"] },
          { "path": "docs/**", "contains_all": ["receiver", "health", "test"] },
          { "path": ".work_products/**", "contains_all": ["receiver", "health", "test"] }
        ]
      },
      {
        "id": "CTX-WEB-002",
        "label": "Mock/live evidence levels are separated",
        "evidence_mode": "any",
        "evidence": [
          { "path": "README.md", "contains_all": ["local", "mock-provider", "live-provider"] },
          { "path": "docs/**", "contains_all": ["local", "mock-provider", "live-provider"] },
          { "path": ".work_products/**", "contains_all": ["local", "mock-provider", "live-provider"] }
        ]
      },
      {
        "id": "CTX-WEB-003",
        "label": "Credential blocker and do-not-retry rule are explicit",
        "evidence_mode": "any",
        "evidence": [
          { "path": "README.md", "contains_all": ["credential", "do-not-retry"] },
          { "path": "docs/**", "contains_all": ["credential", "do-not-retry"] },
          { "path": ".work_products/**", "contains_all": ["credential", "do-not-retry"] }
        ]
      },
      {
        "id": "CTX-WEB-004",
        "label": "Latest RFC/debug status is recoverable",
        "evidence_mode": "any",
        "evidence": [
          { "path": "README.md", "contains_any": ["RFC 1", "RFC 2", "Debug Fix", "next safe action"] },
          { "path": "docs/**", "contains_any": ["RFC 1", "RFC 2", "Debug Fix", "next safe action"] },
          { "path": ".work_products/**", "contains_any": ["RFC 1", "RFC 2", "Debug Fix", "next safe action"] }
        ]
      }
    ],
    "rfc_debug": [
      {
        "id": "RFC-WEB-001",
        "label": "Provider schema v2 is canonical and v1 is rejected",
        "evidence": [
          { "path": "src/**", "contains_all": ["eventId", "eventType", "tenantId"] },
          { "path": "tests/**", "contains_any": ["v1", "v2", "legacy", "rejected"] }
        ]
      },
      {
        "id": "RFC-WEB-002",
        "label": "v2 signing payload includes tenant and raw body",
        "evidence": [
          { "path": "src/**", "contains_all": ["tenantId", "raw body", "signature"] },
          { "path": "tests/**", "contains_any": ["tenantId", "signature"] }
        ]
      },
      {
        "id": "RFC-WEB-003",
        "label": "Tenant secret rotation and replay protection exist",
        "evidence": [
          { "path": "src/**", "contains_all": ["previous secret", "grace", "replay"] },
          { "path": "tests/**", "contains_any": ["previous secret", "expired", "replay"] }
        ]
      },
      {
        "id": "DEBUG-WEB-001",
        "label": "Debug evidence rejects unsafe replay/timestamp/expired-secret path",
        "evidence": [
          { "path": "tests/**", "contains_any": ["stale", "expired", "replay"] },
          { "path": "README.md", "contains_any": ["Debug Fix", "replay", "timestamp"] }
        ]
      }
    ],
    "handoff": [
      {
        "id": "HANDOFF-WEB-001",
        "label": "Next safe action avoids credential guessing and evidence confusion",
        "evidence_mode": "any",
        "evidence": [
          { "path": "README.md", "contains_all": ["next safe action", "do-not-retry", "mock-provider"] },
          { "path": "docs/**", "contains_all": ["next safe action", "do-not-retry", "mock-provider"] },
          { "path": ".work_products/**", "contains_all": ["next safe action", "do-not-retry", "mock-provider"] }
        ]
      }
    ]
  }
}
