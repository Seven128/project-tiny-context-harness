{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Mechanism benchmark agent result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "task_id",
    "variant_id",
    "context_delta",
    "context_files_read",
    "context_read_rounds",
    "verification_commands",
    "conformance_completed"
  ],
  "properties": {
    "task_id": {
      "type": "string"
    },
    "variant_id": {
      "type": "string"
    },
    "context_delta": {
      "enum": [
        "none",
        "required"
      ]
    },
    "context_files_read": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "context_read_rounds": {
      "type": "integer",
      "minimum": 0
    },
    "context_selection_source": {
      "enum": [
        "agent_reported",
        "host_tool_trace",
        "resolver_output"
      ]
    },
    "verification_commands": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "command",
          "status"
        ],
        "properties": {
          "command": {
            "type": "string"
          },
          "status": {
            "enum": [
              "passed",
              "failed",
              "not_run"
            ]
          }
        }
      }
    },
    "conformance_completed": {
      "type": "boolean"
    },
    "preflight_reports": {
      "type": "array"
    },
    "compile_report": {},
    "notes": {
      "type": "string"
    }
  }
}
