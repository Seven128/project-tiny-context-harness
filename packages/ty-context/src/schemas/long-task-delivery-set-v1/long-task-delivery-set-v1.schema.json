{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Seven128/project-tiny-context-harness/schemas/long-task-delivery-set-v1.schema.json",
  "title": "Long-Task Delivery Set V1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "set", "source_claims", "global", "contracts"],
  "properties": {
    "schema_version": { "const": "long-task-delivery-set-v1" },
    "multi_repository_change": { "type": "boolean" },
    "set": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "goal", "source_paths", "context_refs", "context_snapshot_mode"],
      "properties": {
        "id": { "$ref": "#/$defs/key" },
        "title": { "$ref": "#/$defs/nonEmpty" },
        "goal": { "$ref": "#/$defs/nonEmpty" },
        "source_paths": { "$ref": "#/$defs/strings" },
        "context_refs": { "$ref": "#/$defs/strings" },
        "context_snapshot_mode": { "enum": ["referenced", "full"] },
        "risk_floor": { "enum": ["standard", "strict"] }
      }
    },
    "source_claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "../long-task-delivery-v1/long-task-delivery-v1.schema.json#/$defs/sourceClaim"
      }
    },
    "global": {
      "type": "object",
      "additionalProperties": false,
      "required": ["product", "technical", "acceptance"],
      "properties": {
        "product": {
          "type": "object", "additionalProperties": false,
          "required": ["non_goals", "owner_boundaries"],
          "properties": { "non_goals": { "$ref": "#/$defs/strings" }, "owner_boundaries": { "$ref": "#/$defs/strings" } }
        },
        "technical": {
          "type": "object", "additionalProperties": false,
          "required": ["constraints", "forbidden_paths", "forbidden_shortcuts"],
          "properties": { "constraints": { "$ref": "#/$defs/strings" }, "forbidden_paths": { "$ref": "#/$defs/strings" }, "forbidden_shortcuts": { "$ref": "#/$defs/strings" } }
        },
        "acceptance": {
          "type": "object", "additionalProperties": false,
          "required": ["integration_checks"],
          "properties": {
            "integration_checks": { "type": "array", "items": { "$ref": "../long-task-delivery-v1/long-task-delivery-v1.schema.json#/$defs/check" } },
            "external_confirmations": { "type": "array", "items": { "$ref": "../long-task-delivery-v1/long-task-delivery-v1.schema.json#/$defs/externalConfirmation" } }
          }
        }
      }
    },
    "contracts": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/contract" }
    }
  },
  "$defs": {
    "key": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
    "nonEmpty": { "type": "string", "minLength": 1 },
    "strings": { "type": "array", "items": { "$ref": "#/$defs/nonEmpty" } },
    "contract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "workdir", "depends_on", "source_claim_refs", "boundary"],
      "properties": {
        "key": { "$ref": "#/$defs/key" },
        "workdir": { "$ref": "#/$defs/nonEmpty" },
        "depends_on": { "type": "array", "items": { "$ref": "#/$defs/key" } },
        "source_claim_refs": { "type": "array", "items": { "$ref": "#/$defs/key" } },
        "boundary": {
          "type": "object",
          "additionalProperties": false,
          "required": ["observable_result", "separation_reason", "evidence"],
          "properties": {
            "observable_result": { "$ref": "#/$defs/nonEmpty" },
            "separation_reason": { "enum": ["independent_release", "independent_rollback", "different_owner_or_authority", "different_risk_or_approval_boundary", "independent_product_capability"] },
            "evidence": { "$ref": "#/$defs/nonEmpty" }
          }
        }
      }
    }
  }
}
