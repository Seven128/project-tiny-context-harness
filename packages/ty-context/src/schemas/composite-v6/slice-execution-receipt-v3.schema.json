{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://project-tiny-context-harness.invalid/schemas/composite-v6/slice-execution-receipt-v3.schema.json",
  "title": "Composite Campaign detached slice execution receipt V3",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "campaign_id",
    "slice_id",
    "wave_id",
    "worktree_kind",
    "base_commit",
    "head_commit",
    "commit_oids",
    "changed_paths",
    "packet_sha256",
    "contract_sha256",
    "change_envelope_sha256",
    "undeclared_changed_paths",
    "final_result_sha256",
    "final_snapshot_sha256",
    "workflow_status",
    "worktree_clean",
    "recorded_at",
    "receipt_sha256"
  ],
  "properties": {
    "schema_version": { "const": "slice-execution-receipt-v3" },
    "campaign_id": { "$ref": "#/$defs/id" },
    "slice_id": { "type": "string", "pattern": "^SFC-[0-9]{3,}$" },
    "wave_id": { "$ref": "#/$defs/id" },
    "worktree_kind": { "const": "detached" },
    "base_commit": { "$ref": "#/$defs/oid" },
    "head_commit": { "$ref": "#/$defs/oid" },
    "commit_oids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/oid" }
    },
    "changed_paths": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "packet_sha256": { "$ref": "#/$defs/hash" },
    "contract_sha256": { "$ref": "#/$defs/hash" },
    "change_envelope_sha256": { "$ref": "#/$defs/hash" },
    "undeclared_changed_paths": { "type": "array", "maxItems": 0 },
    "final_result_sha256": { "$ref": "#/$defs/hash" },
    "final_snapshot_sha256": { "$ref": "#/$defs/hash" },
    "workflow_status": { "const": "accepted" },
    "worktree_clean": { "const": true },
    "recorded_at": { "type": "string", "format": "date-time" },
    "receipt_sha256": { "$ref": "#/$defs/hash" }
  },
  "$defs": {
    "id": { "type": "string", "minLength": 1, "maxLength": 128 },
    "hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "oid": { "type": "string", "pattern": "^(?:[a-f0-9]{40}|[a-f0-9]{64})$" }
  }
}
