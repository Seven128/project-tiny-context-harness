{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Seven128/project-tiny-context-harness/schemas/long-task-outcomes-v1.schema.json",
  "title": "Canonical Delivery Contract Outcome Fragment V1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "outcomes"],
  "properties": {
    "schema_version": { "const": "long-task-outcomes-v1" },
    "outcomes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "long-task-delivery-v1.schema.json#/$defs/outcome"
      }
    }
  }
}
