{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Seven128/project-tiny-context-harness/schemas/long-task-delivery-v1.schema.json",
  "title": "Canonical Delivery Contract V1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "task", "risk", "global"],
  "oneOf": [
    { "required": ["outcomes"], "not": { "required": ["outcome_files"] } },
    { "required": ["outcome_files"], "not": { "required": ["outcomes"] } }
  ],
  "properties": {
    "schema_version": { "const": "long-task-delivery-v1" },
    "task": { "$ref": "#/$defs/task" },
    "risk": { "$ref": "#/$defs/risk" },
    "global": { "$ref": "#/$defs/global" },
    "source_claims": { "type": "array", "items": { "$ref": "#/$defs/sourceClaim" } },
    "outcomes": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/outcome" } },
    "outcome_files": { "$ref": "#/$defs/strings" }
  },
  "$defs": {
    "key": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
    "nonEmpty": { "type": "string", "minLength": 1 },
    "strings": { "type": "array", "items": { "$ref": "#/$defs/nonEmpty" } },
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "goal", "source_paths", "context_refs", "context_snapshot_mode"],
      "properties": {
        "id": { "$ref": "#/$defs/key" },
        "title": { "$ref": "#/$defs/nonEmpty" },
        "goal": { "$ref": "#/$defs/nonEmpty" },
        "source_paths": { "$ref": "#/$defs/strings" },
        "context_refs": { "$ref": "#/$defs/strings" },
        "context_snapshot_mode": { "enum": ["referenced", "full"] }
      }
    },
    "risk": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requested_level", "facts"],
      "properties": {
        "requested_level": { "enum": ["auto", "standard", "strict"] },
        "facts": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "public_api_or_schema_change", "persistent_data_change", "data_migration",
            "security_boundary_change", "permission_boundary_change", "irreversible_external_effect",
            "critical_user_path", "full_population_operation", "multi_repository_change", "weak_observability"
          ],
          "properties": {
            "public_api_or_schema_change": { "type": "boolean" },
            "persistent_data_change": { "type": "boolean" },
            "data_migration": { "type": "boolean" },
            "security_boundary_change": { "type": "boolean" },
            "permission_boundary_change": { "type": "boolean" },
            "irreversible_external_effect": { "type": "boolean" },
            "critical_user_path": { "type": "boolean" },
            "full_population_operation": { "type": "boolean" },
            "multi_repository_change": { "type": "boolean" },
            "weak_observability": { "type": "boolean" }
          }
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "object", "additionalProperties": false,
            "required": ["fact", "source_claim_refs", "context_refs", "affected_paths", "rationale"],
            "properties": {
              "fact": { "enum": ["public_api_or_schema_change", "persistent_data_change", "data_migration", "security_boundary_change", "permission_boundary_change", "irreversible_external_effect", "critical_user_path", "full_population_operation", "multi_repository_change", "weak_observability"] },
              "source_claim_refs": { "$ref": "#/$defs/strings" },
              "context_refs": { "$ref": "#/$defs/strings" },
              "affected_paths": { "$ref": "#/$defs/strings" },
              "rationale": { "$ref": "#/$defs/nonEmpty" }
            }
          }
        }
      }
    },
    "global": {
      "type": "object",
      "additionalProperties": false,
      "required": ["product", "technical", "acceptance"],
      "properties": {
        "product": {
          "type": "object", "additionalProperties": false,
          "required": ["non_goals", "owner_boundaries"],
          "properties": { "non_goals": { "$ref": "#/$defs/strings" }, "owner_boundaries": { "$ref": "#/$defs/strings" } }
        },
        "technical": {
          "type": "object", "additionalProperties": false,
          "required": ["constraints", "forbidden_paths", "forbidden_shortcuts"],
          "properties": {
            "constraints": { "$ref": "#/$defs/strings" },
            "forbidden_paths": { "$ref": "#/$defs/strings" },
            "forbidden_shortcuts": { "$ref": "#/$defs/strings" }
          }
        },
        "acceptance": {
          "type": "object", "additionalProperties": false, "required": ["checks"],
          "properties": {
            "checks": { "type": "array", "items": { "$ref": "#/$defs/check" } },
            "external_confirmations": { "type": "array", "items": { "$ref": "#/$defs/externalConfirmation" } }
          }
        }
      }
    },
    "outcome": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "title", "depends_on", "product", "technical", "acceptance"],
      "properties": {
        "key": { "$ref": "#/$defs/key" },
        "title": { "$ref": "#/$defs/nonEmpty" },
        "depends_on": { "type": "array", "items": { "$ref": "#/$defs/key" } },
        "product": { "$ref": "#/$defs/product" },
        "technical": { "$ref": "#/$defs/technical" },
        "acceptance": { "$ref": "#/$defs/acceptance" }
      }
    },
    "product": {
      "type": "object", "additionalProperties": false,
      "required": ["observable_result", "owner_boundary", "owner_surfaces", "controls", "non_completing_outcomes"],
      "properties": {
        "observable_result": { "$ref": "#/$defs/nonEmpty" },
        "owner_boundary": { "$ref": "#/$defs/nonEmpty" },
        "owner_surfaces": { "$ref": "#/$defs/strings" },
        "controls": { "type": "array", "items": { "$ref": "#/$defs/control" } },
        "non_completing_outcomes": { "$ref": "#/$defs/strings" }
      }
    },
    "control": {
      "type": "object", "additionalProperties": false,
      "required": ["key", "location", "trigger", "input", "loading_state", "empty_state", "success_state", "failure_state", "feedback"],
      "properties": {
        "key": { "$ref": "#/$defs/key" }, "location": { "$ref": "#/$defs/nonEmpty" },
        "trigger": { "$ref": "#/$defs/nonEmpty" }, "input": { "$ref": "#/$defs/nonEmpty" },
        "loading_state": { "$ref": "#/$defs/nonEmpty" }, "empty_state": { "$ref": "#/$defs/nonEmpty" },
        "success_state": { "$ref": "#/$defs/nonEmpty" }, "failure_state": { "$ref": "#/$defs/nonEmpty" },
        "feedback": { "$ref": "#/$defs/nonEmpty" }
      }
    },
    "technical": {
      "type": "object", "additionalProperties": false,
      "required": ["obligations", "expected_change_paths", "allowed_support_paths", "forbidden_paths", "bindings", "forbidden_shortcuts", "rollback_and_recovery"],
      "properties": {
        "obligations": { "$ref": "#/$defs/strings" },
        "expected_change_paths": { "$ref": "#/$defs/strings" },
        "allowed_support_paths": { "$ref": "#/$defs/strings" },
        "forbidden_paths": { "$ref": "#/$defs/strings" },
        "bindings": { "type": "array", "items": { "$ref": "#/$defs/binding" } },
        "forbidden_shortcuts": { "$ref": "#/$defs/strings" },
        "rollback_and_recovery": { "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/rollback" }] }
      }
    },
    "binding": {
      "type": "object", "additionalProperties": false, "required": ["kind", "target", "carrier_paths"],
      "properties": {
        "kind": { "enum": ["path_glob", "file", "symbol", "schema", "route", "runtime_capability"] },
        "target": { "$ref": "#/$defs/nonEmpty" }, "carrier_paths": { "$ref": "#/$defs/strings" },
        "existence": { "enum": ["existing", "planned"] }
      }
    },
    "rollback": {
      "type": "object", "additionalProperties": false, "required": ["rollback", "recovery", "verification_check_keys"],
      "properties": {
        "rollback": { "$ref": "#/$defs/nonEmpty" }, "recovery": { "$ref": "#/$defs/nonEmpty" },
        "verification_check_keys": { "type": "array", "items": { "$ref": "#/$defs/key" } }
      }
    },
    "acceptance": {
      "type": "object", "additionalProperties": false,
      "required": ["validates", "does_not_validate", "checks", "population", "counterfactual_controls"],
      "properties": {
        "validates": { "$ref": "#/$defs/strings" }, "does_not_validate": { "$ref": "#/$defs/strings" },
        "checks": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/check" } },
        "population": { "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/population" }] },
        "counterfactual_controls": { "type": "array", "items": { "$ref": "#/$defs/counterfactual" } }
      }
    },
    "check": {
      "type": "object", "additionalProperties": false,
      "required": ["key", "proof_surface", "runner", "input_paths", "artifact_globs", "positive_assertions", "negative_assertions", "environment_requirements"],
      "properties": {
        "key": { "$ref": "#/$defs/key" },
        "proof_surface": { "enum": ["ui_browser", "runtime_behavior", "api_contract", "data_state", "security_boundary", "population_coverage", "implementation_structure"] },
        "runner": { "$ref": "#/$defs/runner" },
        "verification_sources": { "$ref": "#/$defs/strings" },
        "input_paths": { "$ref": "#/$defs/strings" },
        "expected_output_paths": { "$ref": "#/$defs/strings" },
        "artifact_globs": { "$ref": "#/$defs/strings" },
        "positive_assertions": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/assertion" } },
        "negative_assertions": { "type": "array", "items": { "$ref": "#/$defs/assertion" } },
        "environment_requirements": { "$ref": "#/$defs/strings" }
      }
    },
    "runner": {
      "type": "object", "additionalProperties": false,
      "required": ["type", "target", "argv", "cwd", "timeout_ms", "network_policy"],
      "properties": {
        "type": { "enum": ["package_script", "project_binary", "node_oracle", "playwright_test"] },
        "target": { "$ref": "#/$defs/nonEmpty" }, "argv": { "$ref": "#/$defs/strings" },
        "cwd": { "$ref": "#/$defs/nonEmpty" },
        "timeout_ms": { "type": "integer", "minimum": 100, "maximum": 3600000 },
        "network_policy": { "$ref": "#/$defs/network" },
        "effect": { "enum": ["read_only", "test_sandbox"] },
        "retry_policy": { "enum": ["none", "transient_once"] },
        "idempotent": { "type": "boolean" }
      }
    },
    "network": {
      "type": "object", "additionalProperties": false, "required": ["mode", "allowed_hosts"],
      "properties": { "mode": { "enum": ["none", "loopback", "declared_hosts"] }, "allowed_hosts": { "$ref": "#/$defs/strings" } }
    },
    "assertion": {
      "type": "object", "additionalProperties": false, "required": ["observation", "operator"],
      "properties": {
        "observation": { "$ref": "#/$defs/nonEmpty" },
        "operator": { "enum": ["equals", "not_equals", "contains", "not_contains", "matches", "not_matches", "greater_than", "greater_or_equal", "less_than", "less_or_equal", "truthy", "falsy", "exists", "not_exists", "set_equals", "subset_of", "superset_of"] },
        "expected": {}
      }
    },
    "population": {
      "type": "object", "additionalProperties": false,
      "required": ["check_key", "observation", "required_coverage_percent", "exclusion_rules"],
      "properties": {
        "check_key": { "$ref": "#/$defs/key" }, "observation": { "$ref": "#/$defs/nonEmpty" },
        "required_coverage_percent": { "const": 100 }, "exclusion_rules": { "$ref": "#/$defs/strings" }
      }
    },
    "sourceClaim": {
      "type": "object", "additionalProperties": false,
      "required": ["key", "source_ref", "statement", "disposition"],
      "properties": {
        "key": { "$ref": "#/$defs/key" },
        "source_ref": { "$ref": "#/$defs/nonEmpty" },
        "statement": { "$ref": "#/$defs/nonEmpty" },
        "disposition": {
          "oneOf": [
            { "type": "object", "additionalProperties": false, "required": ["type", "refs"], "properties": { "type": { "enum": ["contract", "global_constraint"] }, "refs": { "$ref": "#/$defs/strings" } } },
            { "type": "object", "additionalProperties": false, "required": ["type", "reason"], "properties": { "type": { "enum": ["out_of_scope", "decision_required"] }, "reason": { "$ref": "#/$defs/nonEmpty" } } }
          ]
        }
      }
    },
    "externalConfirmation": {
      "type": "object", "additionalProperties": false,
      "required": ["key", "description", "owner"],
      "properties": { "key": { "$ref": "#/$defs/key" }, "description": { "$ref": "#/$defs/nonEmpty" }, "owner": { "$ref": "#/$defs/nonEmpty" } }
    },
    "counterfactual": {
      "type": "object", "additionalProperties": false, "required": ["check_key", "mutation", "expect"],
      "properties": {
        "check_key": { "$ref": "#/$defs/key" }, "expect": { "const": "check_fails" },
        "mutation": {
          "oneOf": [
            {
              "type": "object", "additionalProperties": false, "required": ["type", "paths"],
              "properties": { "type": { "const": "remove_paths" }, "paths": { "$ref": "#/$defs/strings" } }
            },
            {
              "type": "object", "additionalProperties": false, "required": ["type", "path", "fixture_path"],
              "properties": {
                "type": { "const": "replace_file" }, "path": { "$ref": "#/$defs/nonEmpty" },
                "fixture_path": { "$ref": "#/$defs/nonEmpty" }
              }
            }
          ]
        }
      }
    }
  }
}
