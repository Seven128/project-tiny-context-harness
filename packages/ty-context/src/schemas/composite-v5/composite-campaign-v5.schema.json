{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://project-tiny-context-harness.invalid/schemas/composite-v5/composite-campaign-v5.schema.json",
  "title": "Composite Campaign V5",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "campaign_id", "source_plan_sha256", "source_kind", "created_at", "target_branch", "base_commit", "integration_branch", "integration_head", "graph", "slices", "waves", "generation", "campaign_status", "context_baseline", "campaign_policy", "execution_host", "repair_threads"],
  "properties": {
    "schema_version": { "const": "composite-campaign-v5" }, "campaign_id": { "$ref": "#/$defs/text" }, "source_plan_sha256": { "$ref": "#/$defs/sha256" }, "source_kind": { "const": "discussed_plan" }, "created_at": { "type": "string", "format": "date-time" }, "target_branch": { "$ref": "#/$defs/text" }, "base_commit": { "$ref": "#/$defs/nullableOid" }, "integration_branch": { "$ref": "#/$defs/text" }, "integration_head": { "$ref": "#/$defs/nullableOid" },
    "graph": { "$ref": "#/$defs/graph" }, "slices": { "type": "object", "propertyNames": { "pattern": "^SFC-[0-9]{3,}$" }, "additionalProperties": { "$ref": "#/$defs/slice" } }, "waves": { "type": "object", "additionalProperties": { "$ref": "#/$defs/wave" } }, "generation": { "type": "integer", "minimum": 1 }, "campaign_status": { "enum": ["planning", "authoring", "executing", "integrating", "finalizing", "accepted", "decision_blocked", "externally_blocked"] }, "context_baseline": { "$ref": "#/$defs/contextBaseline" }, "campaign_policy": { "$ref": "#/$defs/campaignPolicy" }, "execution_host": { "$ref": "#/$defs/executionHost" }, "repair_threads": { "type": "object", "additionalProperties": { "$ref": "#/$defs/repairThread" } }
  },
  "$defs": {
    "text": { "type": "string", "minLength": 1 }, "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }, "oid": { "type": "string", "pattern": "^(?:[a-f0-9]{40}|[a-f0-9]{64})$" }, "nullableText": { "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/text" }] }, "nullableSha256": { "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/sha256" }] }, "nullableOid": { "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/oid" }] }, "stringSet": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/text" } },
    "contextFile": { "type": "object", "additionalProperties": false, "required": ["path", "sha256"], "properties": { "path": { "type": "string", "pattern": "^project_context/(?!.*(?:^|/)\\.\\.(?:/|$))[^\\\\]+\\.(?:md|toml)$" }, "sha256": { "$ref": "#/$defs/sha256" } } },
    "contextBaseline": { "type": "object", "additionalProperties": false, "required": ["context_graph_sha256", "context_baseline_sha256", "context_files"], "properties": { "context_graph_sha256": { "$ref": "#/$defs/sha256" }, "context_baseline_sha256": { "$ref": "#/$defs/sha256" }, "context_files": { "type": "array", "minItems": 3, "uniqueItems": true, "items": { "$ref": "#/$defs/contextFile" } } } },
    "campaignPolicy": { "type": "object", "additionalProperties": false, "required": ["auto_push", "protected_branch_mode", "preserve_primary_worktree"], "properties": { "auto_push": { "type": "boolean" }, "protected_branch_mode": { "const": "pull_request" }, "preserve_primary_worktree": { "const": true } } },
    "modelProfile": { "type": "object", "additionalProperties": false, "required": ["model", "effort"], "properties": { "model": { "$ref": "#/$defs/text" }, "effort": { "$ref": "#/$defs/text" } } },
    "nullableModelProfile": { "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/modelProfile" }] },
    "threadGoal": { "type": "object", "additionalProperties": false, "required": ["status", "objective_sha256"], "properties": { "status": { "enum": ["not_set", "active", "complete", "blocked"] }, "objective_sha256": { "$ref": "#/$defs/nullableSha256" } } },
    "thread": {
      "type": "object", "additionalProperties": false,
      "required": ["thread_id", "session_id", "phase", "authoring_profile", "execution_profile", "routing_reason", "routing_freeze", "authoring_turn_ids", "goal", "execution_turn_ids", "turn_observations", "active_turn_id", "last_turn_status", "launch_token", "last_error_code"],
      "properties": {
        "thread_id": { "$ref": "#/$defs/nullableText" }, "session_id": { "$ref": "#/$defs/nullableText" }, "phase": { "enum": ["thread_pending", "authoring", "packet_validation", "worktree_ready", "goal_active", "executing", "accepted", "failed", "interrupted"] }, "authoring_profile": { "$ref": "#/$defs/nullableModelProfile" }, "execution_profile": { "$ref": "#/$defs/nullableModelProfile" }, "routing_reason": { "oneOf": [{ "type": "null" }, { "enum": ["sol_xhigh_to_medium", "sol_max_to_medium", "catalog_upgrade_to_sol_medium", "below_threshold_passthrough", "unknown_profile_passthrough", "target_unavailable_passthrough"] }] }, "routing_freeze": { "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/routingFreeze" }] }, "authoring_turn_ids": { "$ref": "#/$defs/stringSet" }, "goal": { "$ref": "#/$defs/threadGoal" }, "execution_turn_ids": { "$ref": "#/$defs/stringSet" }, "turn_observations": { "type": "object", "additionalProperties": { "$ref": "#/$defs/turnObservation" } }, "active_turn_id": { "$ref": "#/$defs/nullableText" }, "last_turn_status": { "enum": ["idle", "inProgress", "completed", "interrupted", "failed", "system_error"] }, "launch_token": { "$ref": "#/$defs/nullableText" }, "last_error_code": { "$ref": "#/$defs/nullableText" }
      }
    },
    "turnObservation": { "type": "object", "additionalProperties": false, "required": ["turn_id", "kind", "status", "observed_at", "reconciliation_required"], "properties": { "turn_id": { "$ref": "#/$defs/text" }, "kind": { "enum": ["authoring", "execution"] }, "status": { "enum": ["running", "completed", "failed", "interrupted", "unknown"] }, "observed_at": { "type": "string", "format": "date-time" }, "reconciliation_required": { "type": "boolean" } } },
    "routingDecision": { "type": "object", "additionalProperties": false, "required": ["authoring_profile", "execution_profile", "switched", "reason"], "properties": { "authoring_profile": { "$ref": "#/$defs/modelProfile" }, "execution_profile": { "$ref": "#/$defs/modelProfile" }, "switched": { "type": "boolean" }, "reason": { "enum": ["sol_xhigh_to_medium", "sol_max_to_medium", "catalog_upgrade_to_sol_medium", "below_threshold_passthrough", "unknown_profile_passthrough", "target_unavailable_passthrough"] } } },
    "routingFreeze": { "type": "object", "additionalProperties": false, "required": ["policy_id", "policy_sha256", "catalog_sha256", "routing_decision", "decision_sha256"], "properties": { "policy_id": { "$ref": "#/$defs/text" }, "policy_sha256": { "$ref": "#/$defs/sha256" }, "catalog_sha256": { "$ref": "#/$defs/sha256" }, "routing_decision": { "$ref": "#/$defs/routingDecision" }, "decision_sha256": { "$ref": "#/$defs/sha256" } } },
    "graphSlice": { "type": "object", "additionalProperties": false, "required": ["stable_key", "depends_on", "priority"], "properties": { "stable_key": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{0,127}$" }, "depends_on": { "type": "array", "uniqueItems": true, "items": { "type": "string", "pattern": "^SFC-[0-9]{3,}$" } }, "priority": { "type": "integer", "minimum": 0 } } },
    "graph": { "type": "object", "additionalProperties": false, "required": ["graph_revision", "graph_sha256", "slices"], "properties": { "graph_revision": { "type": "integer", "minimum": 0 }, "graph_sha256": { "$ref": "#/$defs/sha256" }, "slices": { "type": "object", "propertyNames": { "pattern": "^SFC-[0-9]{3,}$" }, "additionalProperties": { "$ref": "#/$defs/graphSlice" } } } },
    "slice": {
      "type": "object", "additionalProperties": false,
      "required": ["status", "packet_revision", "packet_sha256", "wave_id", "branch", "worktree", "goal_id", "base_commit", "head_commit", "final_receipt_sha256", "merge_commit", "thread"],
      "properties": { "status": { "enum": ["planned", "packet_pending", "packet_ready", "scheduled", "worktree_ready", "goal_running", "accepted", "merge_pending", "merged", "integration_verified", "decision_blocked", "externally_blocked"] }, "packet_revision": { "oneOf": [{ "type": "null" }, { "type": "integer", "minimum": 1 }] }, "packet_sha256": { "$ref": "#/$defs/nullableSha256" }, "wave_id": { "$ref": "#/$defs/nullableText" }, "branch": { "$ref": "#/$defs/nullableText" }, "worktree": { "$ref": "#/$defs/nullableText" }, "goal_id": { "$ref": "#/$defs/nullableText" }, "base_commit": { "$ref": "#/$defs/nullableOid" }, "head_commit": { "$ref": "#/$defs/nullableOid" }, "final_receipt_sha256": { "$ref": "#/$defs/nullableSha256" }, "merge_commit": { "$ref": "#/$defs/nullableOid" }, "thread": { "$ref": "#/$defs/thread" } }
    },
    "wave": { "type": "object", "additionalProperties": false, "required": ["base_commit", "slice_ids", "status", "schedule_sha256", "integration_result_sha256"], "properties": { "base_commit": { "$ref": "#/$defs/oid" }, "slice_ids": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "pattern": "^SFC-[0-9]{3,}$" } }, "status": { "enum": ["scheduled", "running", "accepted", "merged", "integration_verified", "repair_required", "decision_blocked", "externally_blocked"] }, "schedule_sha256": { "$ref": "#/$defs/sha256" }, "integration_result_sha256": { "$ref": "#/$defs/nullableSha256" } } },
    "controllerProfile": { "type": "object", "additionalProperties": false, "required": ["model", "effort", "source"], "properties": { "model": { "$ref": "#/$defs/nullableText" }, "effort": { "$ref": "#/$defs/nullableText" }, "source": { "enum": ["controller_thread", "host_explicit", "unknown"] } } },
    "executionHost": { "type": "object", "additionalProperties": false, "required": ["kind", "controller_thread_id", "controller_profile", "model_catalog_sha256", "app_server_version", "status", "restart_count", "last_error_code"], "properties": { "kind": { "const": "codex_app_server" }, "controller_thread_id": { "$ref": "#/$defs/nullableText" }, "controller_profile": { "$ref": "#/$defs/controllerProfile" }, "model_catalog_sha256": { "$ref": "#/$defs/nullableSha256" }, "app_server_version": { "$ref": "#/$defs/nullableText" }, "status": { "enum": ["disconnected", "connected", "reconnecting", "wait_external"] }, "restart_count": { "enum": [0, 1] }, "last_error_code": { "$ref": "#/$defs/nullableText" } } },
    "repairThread": { "type": "object", "additionalProperties": false, "required": ["wave_id", "repair_id", "thread"], "properties": { "wave_id": { "$ref": "#/$defs/text" }, "repair_id": { "$ref": "#/$defs/text" }, "thread": { "$ref": "#/$defs/thread" } } }
  }
}
