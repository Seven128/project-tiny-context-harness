{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://project-tiny-context-harness.invalid/schemas/composite-v5/scope-fit-result-v4.schema.json",
  "title": "Scope Fit Result V4",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "request_sha256", "decision", "campaign_goal", "granularity_contract", "source_units", "global_constraints", "slices"],
  "properties": {
    "schema_version": { "const": "scope-fit-result-v4" },
    "request_sha256": { "$ref": "#/$defs/sha256" },
    "decision": { "enum": ["fit_for_three_inputs", "split_required", "blocked_for_decision", "not_long_task"] },
    "campaign_goal": { "$ref": "#/$defs/text" },
    "rationale": { "$ref": "#/$defs/textArray" },
    "granularity_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["unit", "slice_policy", "parallelism_must_not_force_split"],
      "properties": {
        "unit": { "const": "control_or_capability_unit" },
        "slice_policy": { "const": "maximal_coherent_authorable_scope" },
        "parallelism_must_not_force_split": { "const": true }
      }
    },
    "source_units": { "type": "array", "items": { "$ref": "#/$defs/sourceUnit" } },
    "global_constraints": { "type": "array", "items": { "$ref": "#/$defs/globalConstraint" } },
    "slices": { "type": "array", "items": { "$ref": "#/$defs/slice" } },
    "decision_required": { "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/decisionRequired" }] }
  },
  "allOf": [
    { "if": { "properties": { "decision": { "const": "fit_for_three_inputs" } } }, "then": { "properties": { "slices": { "minItems": 1, "maxItems": 1 } } } },
    { "if": { "properties": { "decision": { "const": "split_required" } } }, "then": { "properties": { "slices": { "minItems": 2 } } } },
    { "if": { "properties": { "decision": { "const": "blocked_for_decision" } } }, "then": { "required": ["decision_required"], "properties": { "decision_required": { "$ref": "#/$defs/decisionRequired" } } } },
    { "if": { "properties": { "decision": { "const": "not_long_task" } } }, "then": { "properties": { "source_units": { "maxItems": 0 }, "global_constraints": { "maxItems": 0 }, "slices": { "maxItems": 0 } } } }
  ],
  "$defs": {
    "text": { "type": "string", "minLength": 1 },
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "portable": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$" },
    "token": { "type": "string", "minLength": 1, "maxLength": 300, "pattern": "^\\S+$" },
    "textArray": { "type": "array", "items": { "$ref": "#/$defs/text" } },
    "tokenArray": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/token" } },
    "sourceRefs": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "pattern": "^SRC-[0-9]{3,}$" } },
    "sourceUnitRefs": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "pattern": "^SRCU-[0-9]{3,}$" } },
    "sliceRefs": { "type": "array", "uniqueItems": true, "items": { "type": "string", "pattern": "^SFC-[0-9]{3,}$" } },
    "uiDetails": {
      "type": "object", "additionalProperties": false,
      "required": ["owner_surface", "route_or_location", "control", "trigger_or_action", "input", "loading_state", "empty_state", "success_state", "failure_state", "state_transition", "observable_feedback", "api_or_data_dependency", "permission_boundary", "acceptance_evidence"],
      "properties": {
        "owner_surface": { "$ref": "#/$defs/text" }, "route_or_location": { "$ref": "#/$defs/text" }, "control": { "$ref": "#/$defs/text" }, "trigger_or_action": { "$ref": "#/$defs/text" }, "input": { "$ref": "#/$defs/text" }, "loading_state": { "$ref": "#/$defs/text" }, "empty_state": { "$ref": "#/$defs/text" }, "success_state": { "$ref": "#/$defs/text" }, "failure_state": { "$ref": "#/$defs/text" }, "state_transition": { "$ref": "#/$defs/text" }, "observable_feedback": { "$ref": "#/$defs/text" }, "api_or_data_dependency": { "$ref": "#/$defs/text" }, "permission_boundary": { "$ref": "#/$defs/text" }, "acceptance_evidence": { "$ref": "#/$defs/text" }
      }
    },
    "apiDetails": {
      "type": "object", "additionalProperties": false,
      "required": ["endpoint", "method", "request_schema", "response_schema", "validation", "error_semantics", "authorization", "state_effect", "caller", "acceptance_evidence"],
      "properties": {
        "endpoint": { "$ref": "#/$defs/text" }, "method": { "$ref": "#/$defs/text" }, "request_schema": { "$ref": "#/$defs/text" }, "response_schema": { "$ref": "#/$defs/text" }, "validation": { "$ref": "#/$defs/text" }, "error_semantics": { "$ref": "#/$defs/text" }, "authorization": { "$ref": "#/$defs/text" }, "state_effect": { "$ref": "#/$defs/text" }, "caller": { "$ref": "#/$defs/text" }, "acceptance_evidence": { "$ref": "#/$defs/text" }
      }
    },
    "runtimeDetails": {
      "type": "object", "additionalProperties": false,
      "required": ["trigger", "input", "state_transition", "side_effect", "retry", "failure", "recovery", "observable_output", "acceptance_evidence"],
      "properties": {
        "trigger": { "$ref": "#/$defs/text" }, "input": { "$ref": "#/$defs/text" }, "state_transition": { "$ref": "#/$defs/text" }, "side_effect": { "$ref": "#/$defs/text" }, "retry": { "$ref": "#/$defs/text" }, "failure": { "$ref": "#/$defs/text" }, "recovery": { "$ref": "#/$defs/text" }, "observable_output": { "$ref": "#/$defs/text" }, "acceptance_evidence": { "$ref": "#/$defs/text" }
      }
    },
    "basicDetails": { "type": "object", "additionalProperties": false, "required": ["acceptance_evidence"], "properties": { "acceptance_evidence": { "$ref": "#/$defs/text" } } },
    "sourceUnit": {
      "type": "object", "additionalProperties": false,
      "required": ["unit_id", "kind", "statement", "cohesion_key", "owner_boundary", "acceptance_outcome", "source_refs", "details"],
      "properties": {
        "unit_id": { "type": "string", "pattern": "^SRCU-[0-9]{3,}$" },
        "kind": { "enum": ["ui_control", "route", "api_operation", "state_transition", "worker_action", "data_schema", "security_rule", "cli_command", "migration", "integration_contract"] },
        "statement": { "$ref": "#/$defs/text" }, "cohesion_key": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{0,127}$" }, "owner_boundary": { "$ref": "#/$defs/text" }, "acceptance_outcome": { "$ref": "#/$defs/text" }, "source_refs": { "$ref": "#/$defs/sourceRefs" }, "details": {}
      },
      "allOf": [
        { "if": { "properties": { "kind": { "const": "ui_control" } } }, "then": { "properties": { "details": { "$ref": "#/$defs/uiDetails" } } } },
        { "if": { "properties": { "kind": { "const": "api_operation" } } }, "then": { "properties": { "details": { "$ref": "#/$defs/apiDetails" } } } },
        { "if": { "properties": { "kind": { "enum": ["state_transition", "worker_action"] } } }, "then": { "properties": { "details": { "$ref": "#/$defs/runtimeDetails" } } } },
        { "if": { "properties": { "kind": { "enum": ["route", "data_schema", "security_rule", "cli_command", "migration", "integration_contract"] } } }, "then": { "properties": { "details": { "$ref": "#/$defs/basicDetails" } } } }
      ]
    },
    "capacityEvidence": {
      "type": "object", "additionalProperties": false, "required": ["kind", "attempts", "evidence"],
      "properties": { "kind": { "enum": ["output_truncated", "structured_output_failed", "two_repairs_failed", "file_limit_exceeded", "incomplete_unit_mapping"] }, "attempts": { "type": "integer", "minimum": 1 }, "evidence": { "$ref": "#/$defs/text" } },
      "allOf": [{ "if": { "properties": { "kind": { "const": "two_repairs_failed" } } }, "then": { "properties": { "attempts": { "minimum": 3 } } } }]
    },
    "slice": {
      "type": "object", "additionalProperties": false,
      "required": ["slice_id", "stable_key", "title", "objective", "depends_on", "priority", "source_refs", "source_unit_refs", "scope_summary", "out_of_scope", "separation_reasons", "produces_contracts", "consumes_contracts", "conflict_domains", "resource_locks"],
      "properties": {
        "slice_id": { "type": "string", "pattern": "^SFC-[0-9]{3,}$" }, "stable_key": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{0,127}$" }, "title": { "$ref": "#/$defs/text" }, "objective": { "$ref": "#/$defs/text" }, "depends_on": { "$ref": "#/$defs/sliceRefs" }, "priority": { "type": "integer", "minimum": 0 }, "source_refs": { "$ref": "#/$defs/sourceRefs" }, "source_unit_refs": { "$ref": "#/$defs/sourceUnitRefs" }, "scope_summary": { "$ref": "#/$defs/textArray" }, "out_of_scope": { "$ref": "#/$defs/textArray" },
        "separation_reasons": { "type": "array", "uniqueItems": true, "items": { "enum": ["independent_acceptance_outcome", "semantic_dependency", "different_owner_or_authority", "separate_rollout_or_rollback", "unresolved_product_decision", "authoring_capacity_exceeded"] } },
        "authoring_capacity_evidence": { "type": "array", "items": { "$ref": "#/$defs/capacityEvidence" } }, "produces_contracts": { "$ref": "#/$defs/tokenArray" }, "consumes_contracts": { "$ref": "#/$defs/tokenArray" }, "conflict_domains": { "$ref": "#/$defs/tokenArray" }, "resource_locks": { "$ref": "#/$defs/tokenArray" }, "migration_sequences": { "$ref": "#/$defs/tokenArray" }, "generated_artifacts": { "$ref": "#/$defs/tokenArray" }, "package_manager_manifests": { "$ref": "#/$defs/tokenArray" }, "environment_profiles": { "$ref": "#/$defs/tokenArray" }
      },
      "allOf": [{ "if": { "properties": { "separation_reasons": { "contains": { "const": "authoring_capacity_exceeded" } } } }, "then": { "required": ["authoring_capacity_evidence"], "properties": { "authoring_capacity_evidence": { "minItems": 1 } } }, "else": { "properties": { "authoring_capacity_evidence": { "maxItems": 0 } } } }]
    },
    "globalConstraint": { "type": "object", "additionalProperties": false, "required": ["constraint_id", "statement", "applies_to"], "properties": { "constraint_id": { "type": "string", "pattern": "^GC-[0-9]{3,}$" }, "statement": { "$ref": "#/$defs/text" }, "applies_to": { "$ref": "#/$defs/sliceRefs" } } },
    "decisionRequired": { "type": "object", "additionalProperties": false, "required": ["decision_id", "question", "candidates"], "properties": { "decision_id": { "$ref": "#/$defs/portable" }, "question": { "$ref": "#/$defs/text" }, "candidates": { "$ref": "#/$defs/sliceRefs" } } }
  }
}
