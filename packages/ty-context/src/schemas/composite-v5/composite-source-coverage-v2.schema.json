{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://project-tiny-context-harness.invalid/schemas/composite-v5/composite-source-coverage-v2.schema.json",
  "title": "Composite Source Coverage V2",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "source_plan_sha256", "items", "global_constraint_bindings"],
  "properties": {
    "schema_version": { "const": "composite-source-coverage-v2" },
    "source_plan_sha256": { "$ref": "#/$defs/sha256" },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/item" }
    },
    "global_constraint_bindings": {
      "type": "array",
      "items": { "$ref": "#/$defs/globalBinding" }
    }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "text": { "type": "string", "minLength": 1 },
    "sourceId": { "type": "string", "pattern": "^SRC-[0-9]{3,}$" },
    "sliceId": { "type": "string", "pattern": "^SFC-[0-9]{3,}$" },
    "constraintId": { "type": "string", "pattern": "^GC-[0-9]{3,}$" },
    "token": { "type": "string", "pattern": "^[^\\s]+$" },
    "contextRef": {
      "type": "string",
      "pattern": "^project_context/(?!.*(?:^|/)\\.\\.(?:/|$))[^\\\\]+\\.(?:md|toml)$"
    },
    "contextResolution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "context_refs", "task_local_reason"],
      "properties": {
        "status": { "enum": ["existing", "updated", "task_local"] },
        "context_refs": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/contextRef" }
        },
        "task_local_reason": {
          "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/text" }]
        }
      },
      "allOf": [
        {
          "if": { "properties": { "status": { "enum": ["existing", "updated"] } }, "required": ["status"] },
          "then": {
            "properties": {
              "context_refs": { "minItems": 1 },
              "task_local_reason": { "type": "null" }
            }
          },
          "else": {
            "properties": {
              "context_refs": { "maxItems": 0 },
              "task_local_reason": { "$ref": "#/$defs/text" }
            }
          }
        }
      ]
    },
    "item": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_item_id", "statement", "disposition", "slice_refs", "global_constraint_refs", "rationale", "context_resolution"],
      "properties": {
        "source_item_id": { "$ref": "#/$defs/sourceId" },
        "statement": { "$ref": "#/$defs/text" },
        "disposition": { "enum": ["slice", "global_constraint", "out_of_scope", "decision_required"] },
        "slice_refs": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/sliceId" } },
        "global_constraint_refs": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/constraintId" } },
        "rationale": { "$ref": "#/$defs/text" },
        "context_resolution": { "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/contextResolution" }] }
      },
      "allOf": [
        {
          "if": { "properties": { "disposition": { "enum": ["out_of_scope", "decision_required"] } }, "required": ["disposition"] },
          "then": { "properties": { "context_resolution": { "type": "null" } } },
          "else": { "properties": { "context_resolution": { "$ref": "#/$defs/contextResolution" } } }
        }
      ]
    },
    "globalBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["constraint_id", "slice_id", "requirement_ids", "acceptance_criterion_ids", "verification_spec_ids"],
      "properties": {
        "constraint_id": { "$ref": "#/$defs/constraintId" },
        "slice_id": { "$ref": "#/$defs/sliceId" },
        "requirement_ids": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "#/$defs/token" } },
        "acceptance_criterion_ids": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "#/$defs/token" } },
        "verification_spec_ids": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "#/$defs/token" } }
      }
    }
  }
}
