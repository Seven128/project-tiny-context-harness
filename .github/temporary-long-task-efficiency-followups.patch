diff --git a/tools/npm_command_spec.mjs b/tools/npm_command_spec.mjs
new file mode 100644
index 0000000000000000000000000000000000000000..db037ad198cbb2cfe2d38822ae07efe380473475
--- /dev/null
+++ b/tools/npm_command_spec.mjs
@@ -0,0 +1,12 @@
+export function npmCommandSpec(
+  args,
+  { platform = process.platform, environment = process.env } = {},
+) {
+  if (platform === "win32") {
+    return {
+      command: environment.ComSpec || environment.COMSPEC || "cmd.exe",
+      args: ["/d", "/s", "/c", "npm", ...args],
+    };
+  }
+  return { command: "npm", args: [...args] };
+}
